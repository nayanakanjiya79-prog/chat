{
  "$schema": "https://railway.app/railway.json",
  "build": {
    "builder": "NIXPACKS_PYTHON_PACKAGE"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "command": "cd backend && uvicorn main:app --host 0.0.0.0 --port 8080"
  }
}